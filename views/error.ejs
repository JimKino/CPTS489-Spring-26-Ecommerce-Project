<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Error</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="p-5">
  <h1><%= message %></h1>
  <h2><%= error.status || '' %></h2>
  <% if (error.stack) { %>
    <pre><%= error.stack %></pre>
  <% } %>
  <a href="/" class="btn btn-primary">Go to Login</a>
</body>
</html>