<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Search</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/stylesheets/style.css">
  <link rel="stylesheet" href="/stylesheets/UC03 search.css">
</head>
<body>
  <div class="logo">
    <a href="/home">Grocery Store</a>
    <form action="/search" method="GET" class="d-flex" style="gap:8px; flex:1; margin:0 20px;">
      <input type="text" class="form-control" name="q" placeholder="Search" value="<%= q %>">
      <button type="submit" class="btn btn-light">Search</button>
    </form>
    <div style="display:flex; gap:12px; align-items:center;">
      <a href="/cart">Cart</a>
      <a href="/home">Home</a>
    </div>
  </div>

  <div class="searchContainer">
    <div class="filtersContainer">
      <h3>Filters</h3>
      <p>Static filters for demo</p>
    </div>

    <div class="itemsContainer">
      <h3>Search results for "<%= q %>"</h3>

      <% if (noResults) { %>
        <div class="alert alert-warning mt-3">No Products Found</div>
      <% } %>

      <% products.forEach(product => { %>
        <div class="productContainer">
          <div class="productImage">
            <img src="<%= product.image %>" alt="<%= product.name %>">
          </div>
          <div class="productDesc">
            <h1><%= product.name %></h1>
            <h2>$<%= product.price.toFixed(2) %></h2>
            <p><%= product.desc %></p>
            <a class="btn btn-primary" href="/products/<%= product.id %>">View Product</a>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</body>
</html>