<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>UC-012 View Orders</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <link rel="stylesheet" href="/stylesheets/UC-012.css">
</head>
<body>
    <%- include('partials/header') %>

    <div class="mainContainer">
        <aside class="filtersContainer">
            <h2>View Orders</h2>
            <hr>

            <h3>Filters</h3>
            <p class="sectionLabel">Order Status</p>

            <div>
                <input type="checkbox" id="pending">
                <label for="pending">Pending</label>
            </div>

            <div>
                <input type="checkbox" id="shipped">
                <label for="shipped">Shipped</label>
            </div>

            <div>
                <input type="checkbox" id="delivered">
                <label for="delivered">Delivered</label>
            </div>
        </aside>

        <main class="itemsContainer">
            <h2>Orders for My Listings</h2>
            <p class="itemMeta">
                Seller can view customers who purchased their listed items.
            </p>

            <div class="orderCard">
                <div class="orderTop">
                    <div>
                        <h3>Order #1001</h3>
                        <p class="itemMeta">
                            <span class="statusTag">Pending</span>
                            <span class="statusTag">Organic Apples (1 lb)</span>
                        </p>
                        <p class="itemMeta">Customer: Alice Johnson</p>
                        <p class="itemMeta">Quantity: 2</p>
                        <p class="itemMeta">Date: March 3, 2026</p>
                    </div>

                    <div class="orderActions">
                        <a class="btn btnView" href="order-details.html">View</a>
                    </div>
                </div>
            </div>

            <div class="orderCard">
                <div class="orderTop">
                    <div>
                        <h3>Order #1002</h3>
                        <p class="itemMeta">
                            <span class="statusTag">Shipped</span>
                            <span class="statusTag">Milk 2% (1 gallon)</span>
                        </p>
                        <p class="itemMeta">Customer: Michael Lee</p>
                        <p class="itemMeta">Quantity: 1</p>
                        <p class="itemMeta">Date: March 4, 2026</p>
                    </div>

                    <div class="orderActions">
                        <a class="btn btnView" href="order-details.html">View</a>
                    </div>
                </div>
            </div>
        </main>
    </div>
</body>
</html>
