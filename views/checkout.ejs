<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Check out</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/stylesheets/UC06_style.css">
</head>
<body>
  <div class="logo">
    <a href="/home">Grocery Store</a>
    <form action="/search" method="GET" class="d-flex" style="gap:8px; flex:1; margin:0 20px;">
      <input type="text" class="form-control" name="q" placeholder="Search">
      <button type="submit" class="btn btn-light">Search</button>
    </form>
    <div style="display:flex; gap:12px; align-items:center;">
      <a href="/cart">Cart</a>
    </div>
  </div>

  <div class="main">
    <div class="checkout">
      <p>Please input checkout information</p>

      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <form action="/checkout" method="POST">
        <input type="text" name="fname" placeholder="First Name" value="<%= formData.fname || '' %>">
        <input type="text" name="lname" placeholder="Last Name" value="<%= formData.lname || '' %>">
        <input type="text" id="card" name="card" placeholder="Card Number" value="<%= formData.card || '' %>">
        <input type="text" name="expiration" placeholder="Expiration Date" value="<%= formData.expiration || '' %>">
        <input type="text" name="cvv" placeholder="CVV" value="<%= formData.cvv || '' %>">
        <input type="text" id="card" name="address" placeholder="Street Address" value="<%= formData.address || '' %>">
        <input type="text" name="city" placeholder="City" value="<%= formData.city || '' %>">
        <input type="text" name="state" placeholder="State" value="<%= formData.state || '' %>">
        <input type="text" id="card" name="zip" placeholder="Zip Code" value="<%= formData.zip || '' %>">
        <button type="submit">Check out</button>
      </form>
    </div>

    <div class="cart">
      <p>Your Cart</p>
      <table style="width:100%">
        <tr>
          <th>Item</th>
          <th>Quantity</th>
          <th>Cost</th>
        </tr>

        <% cartItems.forEach(item => { %>
          <tr>
            <td><%= item.name %></td>
            <td><%= item.quantity %></td>
            <td>$<%= item.lineTotal.toFixed(2) %></td>
          </tr>
        <% }) %>

        <tr>
          <td></td>
          <th>Subtotal</th>
          <td>$<%= totals.subtotal.toFixed(2) %></td>
        </tr>
        <tr>
          <td></td>
          <th>Tax</th>
          <td>$<%= totals.tax.toFixed(2) %></td>
        </tr>
        <tr>
          <td></td>
          <th>Total</th>
          <td>$<%= totals.total.toFixed(2) %></td>
        </tr>
      </table>
    </div>
  </div>
</body>
</html>