<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Update Profile</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/stylesheets/style.css">
  <link rel="stylesheet" href="/stylesheets/UC08_update_profile.css">
</head>
<body>
  <div class="logo">
    <a href="/home">Grocery Store</a>
    <form action="/search" method="GET" class="d-flex" style="gap:8px; flex:1; margin:0 20px;">
      <input type="text" class="form-control" name="q" placeholder="Search">
      <button type="submit" class="btn btn-light">Search</button>
    </form>
    <div style="display:flex; gap:12px; align-items:center;">
      <a href="/cart">Cart</a>
      <a href="/home">Home</a>
    </div>
  </div>

  <div class="itemsContainer" id="profile_info">
    <h1><%= user.fname %> <%= user.lname %></h1>

    <% if (message) { %>
      <div class="alert alert-success"><%= message %></div>
    <% } %>

    <form action="/profile/update" method="POST" style="max-width:500px;">
      <div class="mb-2">
        <label class="form-label">First Name</label>
        <input class="form-control" type="text" name="fname" value="<%= user.fname %>">
      </div>

      <div class="mb-2">
        <label class="form-label">Last Name</label>
        <input class="form-control" type="text" name="lname" value="<%= user.lname %>">
      </div>

      <div class="mb-2">
        <label class="form-label">Shipping Address</label>
        <input class="form-control" type="text" name="shippingAddress" value="<%= user.shippingAddress %>">
      </div>

      <button type="submit" class="btn btn-primary">Save Profile</button>
    </form>
  </div>

  <div class="itemsContainer" id="payment_info">
    <h1>Payment Information</h1>
    <h2>Saved Cards</h2>

    <% if (user.cards.length === 0) { %>
      <p>No saved cards.</p>
    <% } %>

    <% user.cards.forEach(card => { %>
      <div class="saved_card">
        <table>
          <tr>
            <th>Card name</th>
            <td><%= card.name %></td>
          </tr>
          <tr>
            <th>Card Type</th>
            <td><%= card.type %></td>
          </tr>
          <tr>
            <th>Card Number</th>
            <td>**** **** **** <%= card.last4 %></td>
          </tr>
        </table>
      </div>
    <% }) %>
  </div>
</body>
</html>