<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>UC-011 Edit/Delete Product</title>
  <link rel="stylesheet" href="/stylesheets/style.css">
  <link rel="stylesheet" href="/stylesheets/UC-011.css">
</head>
<body>
  <div class="logo">
    <a href="/home">Grocery Store</a>
    <div class="searchBar">
      <input type="text" placeholder="Search listings">
      <button type="button">Search</button>
    </div>
  </div>

  <div class="mainContainer">
    <aside class="filtersContainer">
      <h2>Edit/Delete Product</h2>
      <hr>
      <h3>My Listings</h3>
      <p class="sectionLabel">Seller can edit or delete their own products.</p>
    </aside>

    <main class="itemsContainer">
      <h2>My Listings</h2>

      <% if (products.length === 0) { %>
        <p>No listings yet.</p>
      <% } %>

      <% products.forEach(product => { %>
        <div class="productCard">
          <div class="productTop">
            <div>
              <h3><%= product.name %></h3>
              <p class="itemMeta">
                <span class="statusTag"><%= product.status %></span>
                <span class="statusTag">$<%= product.price.toFixed(2) %></span>
              </p>
              <p class="itemMeta"><%= product.desc %></p>
              <p class="itemMeta">Stock: <%= product.stock %></p>
            </div>

            <div class="productActions">
              <a class="btn btnEdit" href="/products/<%= product.id %>">View</a>
              <form action="/seller/products/<%= product.id %>/delete" method="POST">
                <button class="btn btnDelete" type="submit">Delete</button>
              </form>
            </div>
          </div>
        </div>
      <% }) %>
    </main>
  </div>
</body>
</html>