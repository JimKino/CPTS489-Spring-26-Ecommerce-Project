 <!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Check out</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">  
    <link rel="stylesheet" href="/stylesheets/style.css">
    <link rel="stylesheet" href="/stylesheets/UC06_style.css">
</head>
    <body>
    <%- include('partials/header') %>

    <div class="main">
        <div class="checkout">
        <h1>Please input checkout information</h1>
        <input type="text" id="fname" placeholder="First Name">
        <input type="text" id="lname" placeholder="Last Name">
        <input type="text" id="card" placeholder="Card Number">
        <input type="text" id="experation" placeholder="Experation Date">
        <input type="text" id="cvv" placeholder="CVV">
        <p class="error" id="error">ERROR: Invalid Information</p>
        <Button type="submit" id ="btnSubmit" class="btn btn-primary">Check out</button>
        </div>
        <div class="cartBox">
            <p>Your Cart</p>
            <table style=width:100%>
            <tr>
                <th>Item</th>
                <th>Quantity</th>
                <th>Cost</th>
            </tr>
            <tr>
                <td>A</td>
                <td>5</td>
                <td>$3.00</td>
            </tr>
            <tr>
                <td>B</td>
                <td>2</td>
                <td>$10.00</td>
            </tr>
            <tr>
                <td>C</td>
                <td>10</td>
                <td>$7.00</td>
            </tr>
            <tr>
                <td></td>
                <th>Subtotal</th>
                <td>$20.00</td>
            </tr>
            <tr>
                <td></td>
                <th>Tax</th>
                <td>$1.60</td>
            </tr>
            <tr>
                <td></td>
                <th>Total</th>
                <td>$21.60</td>
            </tr>
            </table>
        </div>
    </div>
    <script src="javascripts/checkout.js"></script>
    </body>
</html> 
