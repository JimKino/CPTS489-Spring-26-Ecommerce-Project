<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>UC-015 Moderate Reviews</title>
  <link rel="stylesheet" href="/stylesheets/style.css">
  <link rel="stylesheet" href="/stylesheets/UC-015.css">
</head>
<body>
  <div class="logo">
    <a href="/home">Grocery Store</a>
    <div class="searchBar">
      <input type="text" placeholder="Search reviews">
      <button type="button">Search</button>
    </div>
  </div>

  <div class="mainContainer">
    <aside class="filtersContainer">
      <h2>Moderate Reviews</h2>
      <hr>
      <p class="sectionLabel">Admin can remove reviews.</p>
    </aside>

    <main class="itemsContainer">
      <h2>Review Moderation</h2>

      <% if (reviews.length === 0) { %>
        <p>No reviews found.</p>
      <% } %>

      <% reviews.forEach(review => { %>
        <div class="reviewCard">
          <div class="reviewTop">
            <div>
              <h3><%= review.productName %></h3>
              <p class="itemMeta">
                <span class="statusTag"><%= review.flagged ? 'Flagged' : 'Recent' %></span>
                <span class="statusTag">Review ID: R<%= review.id %></span>
              </p>
              <p class="itemMeta"><strong>User:</strong> <%= review.userName %></p>
              <p class="reviewText">"<%= review.body %>"</p>
            </div>

            <div class="reviewActions">
              <form action="/admin/reviews/<%= review.id %>/delete" method="POST">
                <button class="btn btnDelete" type="submit">Delete</button>
              </form>
            </div>
          </div>
        </div>
      <% }) %>
    </main>
  </div>
</body>
</html>