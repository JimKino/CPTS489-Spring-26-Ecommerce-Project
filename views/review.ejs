<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Review Product</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/stylesheets/style.css">
  <link rel="stylesheet" href="/stylesheets/UC09_review.css">
</head>
<body>
  <div class="logo">
    <a href="/home">Grocery Store</a>
    <form action="/search" method="GET" class="d-flex" style="gap:8px; flex:1; margin:0 20px;">
      <input type="text" class="form-control" name="q" placeholder="Search">
      <button type="submit" class="btn btn-light">Search</button>
    </form>
    <div style="display:flex; gap:12px; align-items:center;">
      <a href="/cart">Cart</a>
      <a href="/products/<%= product.id %>">Back to Product</a>
    </div>
  </div>

  <div class="mainContainer">
    <div class="productContainer">
      <div class="productImage">
        <img src="<%= product.image %>" alt="<%= product.name %>">
      </div>
      <div class="productDesc">
        <h1><%= product.name %></h1>
        <h2>$<%= product.price.toFixed(2) %></h2>
        <p><%= product.desc %></p>
      </div>
      <div class="productBuy">
        <h2>$<%= product.price.toFixed(2) %></h2>
        <a href="/products/<%= product.id %>" class="btn btn-primary">View Product</a>
      </div>
    </div>

    <div class="productReviews">
      <h1>Reviews</h1>

      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <div class="input_box">
        <p>Please input review:</p>

        <form action="/review/<%= product.id %>" method="POST" class="mt-3">
          <select class="form-control mb-2" name="rating">
            <option value="5">5 Stars</option>
            <option value="4">4 Stars</option>
            <option value="3">3 Stars</option>
            <option value="2">2 Stars</option>
            <option value="1">1 Star</option>
          </select>

          <input type="text" class="form-control" id="review_header" name="review_header" placeholder="Review Header">
          <textarea class="form-control" id="review_body" name="review_body" placeholder="Type review message here..."></textarea>
          <button type="submit" class="btn btn-primary">Submit Review</button>
        </form>
      </div>
    </div>
  </div>
</body>
</html>