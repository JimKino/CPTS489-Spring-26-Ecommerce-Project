<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Order History</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/stylesheets/UC07_style.css">
</head>
<body>
  <div class="logo">
    <a href="/home">Grocery Store</a>
    <form action="/search" method="GET" class="d-flex" style="gap:8px; flex:1; margin:0 20px;">
      <input type="text" class="form-control" name="q" placeholder="Search">
      <button type="submit" class="btn btn-light">Search</button>
    </form>
    <div style="display:flex; gap:12px; align-items:center;">
      <a href="/cart">Cart</a>
      <a href="/home">Home</a>
    </div>
  </div>

  <div class="main">
    <div class="history">
      <p>Order History</p>

      <% if (orders.length === 0) { %>
        <div class="alert alert-warning">No past orders.</div>
      <% } else { %>
        <table>
          <tr>
            <th>Order Id</th>
            <th>Date</th>
            <th>Item Name</th>
            <th>Quantity</th>
            <th>Cost</th>
          </tr>

          <% orders.forEach(order => { %>
            <% order.items.forEach(item => { %>
              <tr>
                <td><%= order.id %></td>
                <td><%= order.date %></td>
                <td><%= item.name %></td>
                <td><%= item.quantity %></td>
                <td>$<%= item.cost.toFixed(2) %></td>
              </tr>
            <% }) %>
          <% }) %>
        </table>
      <% } %>
    </div>
  </div>
</body>
</html>