<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>UC-014 View System Analytics</title>
  <link rel="stylesheet" href="/stylesheets/style.css">
  <link rel="stylesheet" href="/stylesheets/UC-014.css">
</head>
<body>
  <div class="logo">
    <a href="/home">Grocery Store</a>
    <div class="searchBar">
      <input type="text" placeholder="Search analytics">
      <button type="button">Search</button>
    </div>
  </div>

  <div class="mainContainer">
    <aside class="filtersContainer">
      <h2>View Analytics</h2>
      <hr>
      <p class="sectionLabel">System overview</p>
    </aside>

    <main class="itemsContainer">
      <h2>System Analytics</h2>

      <div class="analyticsCard">
        <h3>Overview</h3>
        <p class="itemMeta"><span class="statusTag">Users: <%= stats.totalUsers %></span></p>
        <p class="itemMeta"><span class="statusTag">Products: <%= stats.totalProducts %></span></p>
        <p class="itemMeta"><span class="statusTag">Orders: <%= stats.totalOrders %></span></p>
        <p class="itemMeta"><span class="statusTag">Revenue: $<%= stats.totalRevenue %></span></p>

        <div class="chartBox">
          <div class="barGroup"><div class="bar bar1"></div><p class="barLabel">Mon</p></div>
          <div class="barGroup"><div class="bar bar2"></div><p class="barLabel">Tue</p></div>
          <div class="barGroup"><div class="bar bar3"></div><p class="barLabel">Wed</p></div>
          <div class="barGroup"><div class="bar bar4"></div><p class="barLabel">Thu</p></div>
          <div class="barGroup"><div class="bar bar5"></div><p class="barLabel">Fri</p></div>
          <div class="barGroup"><div class="bar bar6"></div><p class="barLabel">Sat</p></div>
          <div class="barGroup"><div class="bar bar7"></div><p class="barLabel">Sun</p></div>
        </div>
      </div>
    </main>
  </div>
</body>
</html>