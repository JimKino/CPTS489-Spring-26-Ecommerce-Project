<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Search</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">  
    <link rel="stylesheet" href="/stylesheets/UC03 search.css">
</head>
<body>
    <%- include('partials/header') %>

    <div class="searchContainer">
        <div class="filtersContainer">
            <form action="/search" method="GET">
                <input type="hidden" name="q" value="<%= searchTerm || '' %>">

                <h3>Filters</h3>
                <div>
                    <label>Min Price:</label>
                    <input type="number" name="minPrice" placeholder="0.00" step="0.01" value="<%= minPrice || '' %>">
                </div>
                
                <div>
                    <label>Max Price:</label>
                    <input type="number" name="maxPrice" placeholder="10.99" step="0.01" value="<%= maxPrice || '' %>">
                </div>
                
                <div>
                    <label>
                    <input type="checkbox" name="inStock" value="true" <%= inStock ? 'checked' : '' %>> In Stock Only</label>
                </div>

                <button type="submit" class="addBtn">Apply Filters</button>
            </form>
        </div>
        
        <%- include('partials/productList') %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>
</html>
