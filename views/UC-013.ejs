<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>UC-013 Manage Users</title>
  <link rel="stylesheet" href="/stylesheets/style.css">
  <link rel="stylesheet" href="/stylesheets/UC-013.css">
</head>
<body>
  <div class="logo">
    <a href="/home">Grocery Store</a>
    <div class="searchBar">
      <input type="text" placeholder="Search users">
      <button type="button">Search</button>
    </div>
  </div>

  <div class="mainContainer">
    <aside class="filtersContainer">
      <h2>Manage Users</h2>
      <hr>
      <p class="sectionLabel">Admin can view and delete non-admin accounts.</p>
    </aside>

    <main class="itemsContainer">
      <h2>User Accounts</h2>

      <% users.forEach(user => { %>
        <div class="userCard">
          <div class="userTop">
            <div>
              <h3><%= user.fname %> <%= user.lname %></h3>
              <p class="itemMeta">
                <span class="roleTag"><%= user.role %></span>
                <span class="roleTag">User ID: U<%= user.id %></span>
              </p>
              <p class="itemMeta">Email: <%= user.email %></p>
            </div>

            <div class="userActions">
              <% if (user.role === 'admin') { %>
                <a class="btn btnDisabled" href="#">Cannot Delete</a>
              <% } else { %>
                <form action="/admin/users/<%= user.id %>/delete" method="POST">
                  <button class="btn btnDelete" type="submit">Delete</button>
                </form>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    </main>
  </div>
</body>
</html>