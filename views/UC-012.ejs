<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>UC-012 View Orders</title>
  <link rel="stylesheet" href="/stylesheets/style.css">
  <link rel="stylesheet" href="/stylesheets/UC-012.css">
</head>
<body>
  <div class="logo">
    <a href="/home">Grocery Store</a>
    <div class="searchBar">
      <input type="text" placeholder="Search orders">
      <button type="button">Search</button>
    </div>
  </div>

  <div class="mainContainer">
    <aside class="filtersContainer">
      <h2>View Orders</h2>
      <hr>
      <p class="sectionLabel">Orders for seller products</p>
    </aside>

    <main class="itemsContainer">
      <h2>Orders for My Listings</h2>

      <% if (sellerOrders.length === 0) { %>
        <p>No orders found.</p>
      <% } %>

      <% sellerOrders.forEach(order => { %>
        <div class="orderCard">
          <div class="orderTop">
            <div>
              <h3>Order #<%= order.orderId %></h3>
              <p class="itemMeta">
                <span class="statusTag"><%= order.status %></span>
                <span class="statusTag"><%= order.productName %></span>
              </p>
              <p class="itemMeta">Customer: <%= order.customerName %></p>
              <p class="itemMeta">Quantity: <%= order.quantity %></p>
              <p class="itemMeta">Date: <%= order.date %></p>
            </div>
          </div>
        </div>
      <% }) %>
    </main>
  </div>
</body>
</html>