<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Product</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <link rel="stylesheet" href="/stylesheets/UC10_add_item.css">
</head>
<body>
    <%- include('partials/header') %>

    <div class="mainContainer">
        <div class="productContainer">
            <div class="productImage">
                <h1>Product Image</h1>
                <input id="item_image" type="file" accept="image/*" class="form-control">
                <div id="selectedImg">
                </div>
            </div>
            <div class="productDesc">
                <h1>Product Information</h1>
                <input id="item_name" type="text" class="form-control" id="item_name" placeholder="Product Name">
                <input id="item_price" type="text" class="form-control" id="item_price" placeholder="Product price ($00.00)">
                <input id="item_quantity" type="text" class="form-control" id="item_quantity" placeholder="Quantity">
                <textarea id="item_desc" name="item_desc" class="form-control" rows="17" placeholder="Product Description"></textarea>
                <button id="productsubmit" type="submit" class="btn btn-primary">Add Product</button>
            </div>
        </div>
    </div>
    


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    <script src="javascripts/add_item.js"></script>
</body>
</html>
