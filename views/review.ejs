<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Product</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <link rel="stylesheet" href="/stylesheets/UC09_review.css">
</head>
<body>
    <%- include('partials/header') %>
    
    <div class="mainContainer">
        <div class="productContainer">
            <div class="productImage">
                <img src="/images/Carrot.png">
            </div>
            <div class="productDesc">
                <h1>Carrots</h1>
                <h2>$10.00</h2>
                <p>Fresh carrots</p>
            </div>
            <div class="productBuy">
                <h2>$10.00</h2>
                <button type="submit" class="btn btn-primary">Add to Cart</button>
            </div>
        </div>
        <div class="productReviews">
            <h1>Reviews</h1>
            <div class="input_box">
                <p>Please input review:</p>
                <span class="fa fa-star"></span>
                <span class="fa fa-star"></span>
                <span class="fa fa-star"></span>
                <span class="fa fa-star"></span>
                <span class="fa fa-star"></span>
                <input type="text" class="form-control" id="review_header" placeholder="Review Header">
                <input type="text" class="form-control" id="review_body" placeholder="Type review message here...">
                <button type="submit" class="btn btn-primary">Submit Review</button>
            </div>
        </div>
    </div>
    


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>
</html>
